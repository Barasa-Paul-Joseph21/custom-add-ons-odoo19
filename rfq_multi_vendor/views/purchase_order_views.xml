<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Extend the RFQ / Purchase Order form view -->
    <record id="purchase_order_form_inherit_multi_vendor" model="ir.ui.view">
        <field name="name">purchase.order.form.inherit.multi.vendor</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">

            <!-- Add the Multi-Vendor checkbox near the top of the form -->
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="is_multi_vendor"/>
            </xpath>

            <!-- Add a Multi-Vendor Bids notebook page -->
            <xpath expr="//notebook" position="inside">
                <page string="Multi-Vendor Bids" name="multi_vendor_bids"
                      invisible="not is_multi_vendor">
                    <group string="Bidding">
                        <p class="text-muted">
                            Bid management will be available in the next phase.
                            Enable "Multi-Vendor RFQ" above to use this feature.
                        </p>
                    </group>
                </page>
            </xpath>

        </field>
    </record>

</odoo>
