<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="purchase_bid_form" model="ir.ui.view">
        <field name="name">purchase.bid.form</field>
        <field name="model">purchase.bid</field>
        <field name="arch" type="xml">
            <form string="Vendor Bid">
                <header>
                    <button name="action_submit" type="object" string="Submit Bid" class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_select_winning_bid" type="object" string="Select as Winner" class="oe_highlight" invisible="state != 'submitted'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,submitted,won,lost"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="order_id" readonly="1"/>
                            <field name="partner_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="date_bid"/>
                            <field name="amount_total"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Bid Lines" name="bid_lines">
                            <field name="line_ids">
                                <list string="Lines" editable="bottom">
                                    <field name="product_id" readonly="1"/>
                                    <field name="product_qty" readonly="1"/>
                                    <field name="price_unit"/>
                                    <field name="price_subtotal"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="purchase_bid_tree" model="ir.ui.view">
        <field name="name">purchase.bid.list</field>
        <field name="model">purchase.bid</field>
        <field name="arch" type="xml">
            <list string="Vendor Bids">
                <field name="name"/>
                <field name="order_id"/>
                <field name="partner_id"/>
                <field name="date_bid"/>
                <field name="amount_total"/>
                <field name="state" widget="badge" decoration-success="state == 'won'" decoration-info="state == 'submitted'" decoration-danger="state == 'lost'"/>
            </list>
        </field>
    </record>

    <record id="action_purchase_bid" model="ir.actions.act_window">
        <field name="name">Vendor Bids</field>
        <field name="res_model">purchase.bid</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No bids yet. Create bids from a Multi-Vendor RFQ.
            </p>
        </field>
    </record>

    <menuitem id="menu_purchase_bids" name="Bids" parent="purchase.menu_procurement_management" action="action_purchase_bid" sequence="3"/>

</odoo>
